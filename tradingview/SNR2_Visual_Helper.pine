// ============================================================
// SNR 2.0 視覺輔助工具 - TradingView Pine Script v6
// ============================================================
// 基於林俊宏 SNR 2020 / SR 2.0 支撐阻力交易系統
// 功能: 趨勢線自動偵測 + S/R區域繪製 + EQ/CC高亮 +
//       詳細進場標籤 + R/R視覺化 + 完整警報引擎 + 速查表
// 搭配: SNR2_Strategy.pine (主策略) + SNR2_MTF_Dashboard.pine
// ============================================================

//@version=6
indicator("SNR 2.0 視覺輔助工具", overlay=true, max_lines_count=500,
         max_boxes_count=500, max_labels_count=500, max_bars_back=5000)

// ============================================================
// 輸入參數 (與主策略對齊)
// ============================================================

// --- 水平偵測 (鏡像主策略參數) ---
grp_levels = "═══ 水平偵測參數 (與策略一致) ═══"
swingLookback   = input.int(5, "Swing 回看窗口", minval=2, maxval=20, group=grp_levels)
classicGapRatio  = input.float(0.3, "Classic Gap/ATR 比例", step=0.05, group=grp_levels)
boBodyRatio      = input.float(1.0, "Breakout 實體/ATR 比例", step=0.1, group=grp_levels)
boCleanBars      = input.int(2, "Breakout 乾淨根數", minval=1, maxval=5, group=grp_levels)
gapMinRatio      = input.float(0.2, "Gap 最小/ATR 比例", step=0.05, group=grp_levels)
hnsShoulderRatio = input.float(0.3, "HNS 肩頭比例", step=0.05, group=grp_levels)
hnsTolerance     = input.float(0.5, "HNS 頸線容忍/ATR", step=0.1, group=grp_levels)
maxLevels        = input.int(20, "最大水平數量", minval=5, maxval=50, group=grp_levels)

// --- EQ / CC ---
grp_filter = "═══ EQ & CC 過濾 ═══"
useEQ            = input.bool(true, "啟用 EQ 過濾", group=grp_filter)
eqFreshRatio     = input.float(0.1, "EQ 新鮮容忍/ATR", step=0.05, group=grp_filter)
useCC            = input.bool(true, "啟用 CC 過濾", group=grp_filter)
ccProximityRatio = input.float(0.5, "CC 接近水平/ATR", step=0.1, group=grp_filter)
ccMinBodyRatio   = input.float(0.3, "CC 最小實體/ATR", step=0.05, group=grp_filter)
ccLookback       = input.int(10, "CC 回看根數", minval=3, maxval=20, group=grp_filter)

// --- 進場策略 ---
grp_entry = "═══ 進場策略 ═══"
entryMode = input.string("DC", "進場模式", options=["DC", "DE", "Both"], group=grp_entry)

// --- MTF ---
grp_mtf = "═══ 多時間框架 ═══"
useMTF       = input.bool(true, "啟用 MTF 方向過濾", group=grp_mtf)
htf          = input.timeframe("240", "高階 TF", group=grp_mtf)
mtfPeriod    = input.int(20, "MTF 趨勢計算週期", minval=5, group=grp_mtf)

// --- 風險管理 ---
grp_risk = "═══ 風險管理 ═══"
riskPct        = input.float(1.0, "每筆風險 (%)", step=0.5, group=grp_risk)
defaultTargetR = input.float(1.0, "預設目標 R", step=0.5, group=grp_risk)
maxTargetR     = input.float(3.0, "最大目標 R", step=0.5, group=grp_risk)
beMinRR        = input.float(2.0, "保本移動最低 RR", step=0.5, group=grp_risk)
slBufferRatio  = input.float(0.1, "止損 Buffer/ATR", step=0.05, group=grp_risk)

// --- 趨勢線 ---
grp_tl = "═══ 趨勢線設定 ═══"
showTrendlines   = input.bool(true, "顯示趨勢線", group=grp_tl)
tlMinTouches     = input.int(2, "最少觸碰次數", minval=2, maxval=5, group=grp_tl)
tlMaxCount       = input.int(6, "最大趨勢線數", minval=2, maxval=12, group=grp_tl)
tlTolerance      = input.float(0.15, "觸碰容忍/ATR", step=0.05, group=grp_tl)
tlExtend         = input.int(50, "趨勢線延伸根數", minval=10, maxval=200, group=grp_tl)

// --- 區域繪製 ---
grp_zone = "═══ S/R 區域設定 ═══"
showZones        = input.bool(true, "顯示水平區域 (Box)", group=grp_zone)
zoneThickness    = input.float(0.15, "區域厚度/ATR", step=0.05, group=grp_zone)
showBrokenZones  = input.bool(false, "顯示已突破區域", group=grp_zone)

// --- EQ / CC 高亮 ---
grp_highlight = "═══ EQ / CC 高亮 ═══"
showEQMarkers    = input.bool(true, "顯示 EQ 新鮮標記", group=grp_highlight)
showCCHighlight  = input.bool(true, "顯示 CC K線高亮", group=grp_highlight)
showCCLabels     = input.bool(true, "顯示 CC 標籤", group=grp_highlight)

// --- 詳細進場標籤 ---
grp_labels = "═══ 進場標籤設定 ═══"
showDetailedLabels = input.bool(true, "顯示詳細進場標籤", group=grp_labels)
showRRZones        = input.bool(true, "顯示風險/報酬區域", group=grp_labels)

// --- 速查表 ---
grp_cheat = "═══ 速查表 ═══"
showCheatSheet   = input.bool(true, "顯示 Setup/DE 速查表", group=grp_cheat)
showChecklist    = input.bool(true, "顯示當前情境檢查清單", group=grp_cheat)

// --- 警報 ---
grp_alert = "═══ 警報設定 ═══"
enableAlerts      = input.bool(true, "啟用警報", group=grp_alert)

// ============================================================
// 基礎計算
// ============================================================

atrLen   = 14
atrVal   = ta.atr(atrLen)
bodySize = math.abs(close - open)
bodyTop  = math.max(open, close)
bodyBot  = math.min(open, close)
isBull   = close > open
isBear   = close < open

// ============================================================
// SWING 偵測 + 水平偵測引擎 (鏡像主策略)
// ============================================================

isSwingHigh = ta.pivothigh(high, swingLookback, swingLookback)
isSwingLow  = ta.pivotlow(low, swingLookback, swingLookback)

var float[] swingHighPrices = array.new_float(0)
var int[]   swingHighBars   = array.new_int(0)
var float[] swingLowPrices  = array.new_float(0)
var int[]   swingLowBars    = array.new_int(0)

if not na(isSwingHigh)
    array.push(swingHighPrices, isSwingHigh)
    array.push(swingHighBars, bar_index - swingLookback)
    if array.size(swingHighPrices) > 50
        array.shift(swingHighPrices)
        array.shift(swingHighBars)

if not na(isSwingLow)
    array.push(swingLowPrices, isSwingLow)
    array.push(swingLowBars, bar_index - swingLookback)
    if array.size(swingLowPrices) > 50
        array.shift(swingLowPrices)
        array.shift(swingLowBars)

// --- 擴展水平結構 (加入測試次數 + CC類型) ---
type LevelInfo
    float   price
    int     levelType    // 1=Classic, 2=Breakout, 3=Gap, 4=HNS
    int     side         // 1=Support, -1=Resistance
    int     barIdx
    float   strength
    bool    tested
    bool    broken
    bool    hasCC
    int     testCount    // 被測試次數
    int     ccType       // 0=none, 1=Classic CC, 2=BOCC1, 3=BOCC2, 4=HNS CC
    int     ccBar        // CC K線位置
    float   zoneTop      // 區域上緣
    float   zoneBot      // 區域下緣

var LevelInfo[] levels = array.new<LevelInfo>(0)

// --- Classic 水平 ---
detectClassic() =>
    if not na(isSwingHigh)
        swPrice = isSwingHigh
        swBar   = bar_index - swingLookback
        minGap  = atrVal * classicGapRatio
        hasReaction = false
        for j = 1 to swingLookback * 2
            idx = swBar + j
            if idx <= bar_index and idx >= 0
                if high[bar_index - idx] >= swPrice - minGap and high[bar_index - idx] < swPrice
                    hasReaction := true
                    break
        if hasReaction
            zt = swPrice + atrVal * zoneThickness
            zb = swPrice - atrVal * zoneThickness
            lv = LevelInfo.new(swPrice, 1, -1, swBar, 0.7, false, false, false, 0, 0, 0, zt, zb)
            array.push(levels, lv)

    if not na(isSwingLow)
        swPrice = isSwingLow
        swBar   = bar_index - swingLookback
        minGap  = atrVal * classicGapRatio
        hasReaction = false
        for j = 1 to swingLookback * 2
            idx = swBar + j
            if idx <= bar_index and idx >= 0
                if low[bar_index - idx] <= swPrice + minGap and low[bar_index - idx] > swPrice
                    hasReaction := true
                    break
        if hasReaction
            zt = swPrice + atrVal * zoneThickness
            zb = swPrice - atrVal * zoneThickness
            lv = LevelInfo.new(swPrice, 1, 1, swBar, 0.7, false, false, false, 0, 0, 0, zt, zb)
            array.push(levels, lv)

// --- Breakout 水平 ---
detectBreakout() =>
    localATR = atrVal
    body = bodySize
    if body >= localATR * boBodyRatio
        if isBull
            boPrice = bodyBot
            preClean = true
            for k = 1 to boCleanBars
                if high[k] >= boPrice + localATR * 0.2
                    preClean := false
                    break
            if preClean
                zt = boPrice + atrVal * zoneThickness
                zb = boPrice - atrVal * zoneThickness
                lv = LevelInfo.new(boPrice, 2, 1, bar_index, 0.8, false, false, false, 0, 0, 0, zt, zb)
                array.push(levels, lv)
        else if isBear
            boPrice = bodyTop
            preClean = true
            for k = 1 to boCleanBars
                if low[k] <= boPrice - localATR * 0.2
                    preClean := false
                    break
            if preClean
                zt = boPrice + atrVal * zoneThickness
                zb = boPrice - atrVal * zoneThickness
                lv = LevelInfo.new(boPrice, 2, -1, bar_index, 0.8, false, false, false, 0, 0, 0, zt, zb)
                array.push(levels, lv)

// --- Gap 水平 ---
detectGap() =>
    localATR = atrVal
    minGapSize = localATR * gapMinRatio
    sameColor = (isBull == isBull[1])
    if sameColor
        if isBull
            gapSize = open - close[1]
            if gapSize >= minGapSize
                gapPrice = (close[1] + open) / 2
                zt = math.max(close[1], open)
                zb = math.min(close[1], open)
                lv = LevelInfo.new(gapPrice, 3, 1, bar_index, 0.6, false, false, false, 0, 0, 0, zt, zb)
                array.push(levels, lv)
        else
            gapSize = close[1] - open
            if gapSize >= minGapSize
                gapPrice = (close[1] + open) / 2
                zt = math.max(close[1], open)
                zb = math.min(close[1], open)
                lv = LevelInfo.new(gapPrice, 3, -1, bar_index, 0.6, false, false, false, 0, 0, 0, zt, zb)
                array.push(levels, lv)

// --- HNS 水平 ---
detectHNS() =>
    localATR = atrVal
    if array.size(swingHighPrices) >= 3
        sz = array.size(swingHighPrices)
        leftH  = array.get(swingHighPrices, sz - 3)
        headH  = array.get(swingHighPrices, sz - 2)
        rightH = array.get(swingHighPrices, sz - 1)
        leftBar  = array.get(swingHighBars, sz - 3)
        headBar  = array.get(swingHighBars, sz - 2)
        rightBar = array.get(swingHighBars, sz - 1)
        if headH > leftH and headH > rightH
            shoulderDiff = math.abs(leftH - rightH)
            minShoulder  = math.min(leftH, rightH)
            if shoulderDiff < localATR * (1 - hnsShoulderRatio) and (headH - minShoulder) >= localATR * hnsShoulderRatio
                leftNeck  = 999999999.0
                rightNeck = 999999999.0
                for i = leftBar to headBar
                    offset = bar_index - i
                    if offset >= 0 and offset < bar_index
                        leftNeck := math.min(leftNeck, low[offset])
                for i = headBar to rightBar
                    offset = bar_index - i
                    if offset >= 0 and offset < bar_index
                        rightNeck := math.min(rightNeck, low[offset])
                if math.abs(leftNeck - rightNeck) <= localATR * hnsTolerance and leftNeck < 999999999.0 and rightNeck < 999999999.0
                    neckline = (leftNeck + rightNeck) / 2
                    zt = neckline + atrVal * zoneThickness
                    zb = neckline - atrVal * zoneThickness
                    lv = LevelInfo.new(neckline, 4, 1, rightBar, 0.9, false, false, false, 0, 0, 0, zt, zb)
                    array.push(levels, lv)

    if array.size(swingLowPrices) >= 3
        sz = array.size(swingLowPrices)
        leftL  = array.get(swingLowPrices, sz - 3)
        headL  = array.get(swingLowPrices, sz - 2)
        rightL = array.get(swingLowPrices, sz - 1)
        leftBar  = array.get(swingLowBars, sz - 3)
        headBar  = array.get(swingLowBars, sz - 2)
        rightBar = array.get(swingLowBars, sz - 1)
        if headL < leftL and headL < rightL
            shoulderDiff = math.abs(leftL - rightL)
            maxShoulder  = math.max(leftL, rightL)
            if shoulderDiff < localATR * (1 - hnsShoulderRatio) and (maxShoulder - headL) >= localATR * hnsShoulderRatio
                leftNeck  = -999999999.0
                rightNeck = -999999999.0
                for i = leftBar to headBar
                    offset = bar_index - i
                    if offset >= 0 and offset < bar_index
                        leftNeck := math.max(leftNeck, high[offset])
                for i = headBar to rightBar
                    offset = bar_index - i
                    if offset >= 0 and offset < bar_index
                        rightNeck := math.max(rightNeck, high[offset])
                if math.abs(leftNeck - rightNeck) <= localATR * hnsTolerance and leftNeck > -999999999.0 and rightNeck > -999999999.0
                    neckline = (leftNeck + rightNeck) / 2
                    zt = neckline + atrVal * zoneThickness
                    zb = neckline - atrVal * zoneThickness
                    lv = LevelInfo.new(neckline, 4, -1, rightBar, 0.9, false, false, false, 0, 0, 0, zt, zb)
                    array.push(levels, lv)

// 執行偵測
detectClassic()
detectBreakout()
detectGap()
detectHNS()

// ============================================================
// 水平管理 + EQ測試計數 + CC分類
// ============================================================

updateLevels() =>
    for i = array.size(levels) - 1 to 0
        if i < array.size(levels)
            lv = array.get(levels, i)
            dist = math.abs(close - lv.price)
            if lv.side == 1
                if close < lv.price - atrVal * 0.5
                    lv.broken := true
            else
                if close > lv.price + atrVal * 0.5
                    lv.broken := true
            if dist < atrVal * eqFreshRatio
                if not lv.tested
                    lv.tested := true
                lv.testCount += 1

updateLevels()

// CC 分類偵測 (4種CC類型)
classifyCC() =>
    if useCC
        proximity = atrVal * ccProximityRatio
        minBody   = atrVal * ccMinBodyRatio
        for i = 0 to array.size(levels) - 1
            if i < array.size(levels)
                lv = array.get(levels, i)
                if lv.broken
                    continue
                for k = 1 to ccLookback
                    if k < bar_index
                        ccBody = math.abs(close[k] - open[k])
                        ccBull = close[k] > open[k]
                        ccHighK = high[k]
                        ccLowK  = low[k]
                        dist = 0.0
                        validDir = false
                        if lv.side == 1
                            dist := math.abs(ccLowK - lv.price)
                            validDir := ccBull
                        else
                            dist := math.abs(ccHighK - lv.price)
                            validDir := not ccBull
                        if dist <= proximity and validDir and ccBody >= minBody
                            lv.hasCC := true
                            lv.ccBar := bar_index - k
                            if lv.levelType == 4
                                lv.ccType := 4
                            else if lv.levelType == 2
                                if bar_index - k < lv.barIdx
                                    lv.ccType := 2
                                else
                                    lv.ccType := 3
                            else
                                lv.ccType := 1
                            break

classifyCC()

// 清理水平
cleanLevels() =>
    maxAge = 500
    for i = array.size(levels) - 1 to 0
        if i < array.size(levels)
            lv = array.get(levels, i)
            age = bar_index - lv.barIdx
            if lv.broken and not showBrokenZones
                array.remove(levels, i)
            else if age > maxAge
                array.remove(levels, i)
    while array.size(levels) > maxLevels
        array.shift(levels)

cleanLevels()

isLevelFresh(LevelInfo lv) =>
    result = true
    if useEQ
        result := not lv.tested
    result

// ============================================================
// 多時間框架方向 (鏡像主策略)
// ============================================================

htfClose = request.security(syminfo.tickerid, htf, close)
htfEMA   = request.security(syminfo.tickerid, htf, ta.ema(close, mtfPeriod))
htfBullish = htfClose > htfEMA
htfBearish = htfClose < htfEMA

htfOpen  = request.security(syminfo.tickerid, htf, open)
htfHigh  = request.security(syminfo.tickerid, htf, high)
htfLow   = request.security(syminfo.tickerid, htf, low)
htfBodySize    = math.abs(htfClose - htfOpen)
htfUpperWick   = htfHigh - math.max(htfClose, htfOpen)
htfLowerWick   = math.min(htfClose, htfOpen) - htfLow
htfRejectionUp   = htfUpperWick > htfBodySize * 2
htfRejectionDown = htfLowerWick > htfBodySize * 2

mtfBias = 0
if useMTF
    if htfBullish and not htfRejectionUp
        mtfBias := 1
    else if htfBearish and not htfRejectionDown
        mtfBias := -1

var int prevMtfBias = 0
mtfChanged = mtfBias != prevMtfBias and prevMtfBias != 0
prevMtfBias := mtfBias

// ============================================================
// 趨勢線自動偵測與繪製
// ============================================================

type TrendlineInfo
    float   startPrice
    int     startBar
    float   endPrice
    int     endBar
    float   slope
    int     touches
    int     tlType      // 1=Continuation(111), 2=Breakout(11b2)
    int     direction   // 1=上升, -1=下降

var TrendlineInfo[] trendlines = array.new<TrendlineInfo>(0)
var line[] tlLines = array.new<line>(0)
var label[] tlLabels = array.new<label>(0)

// 每50根重新計算趨勢線
tlRecalcPeriod = 50
shouldRecalcTL = bar_index % tlRecalcPeriod == 0 and showTrendlines

if shouldRecalcTL and array.size(swingLowPrices) >= 3 and array.size(swingHighPrices) >= 3
    // 清除舊趨勢線
    for i = array.size(tlLines) - 1 to 0
        line.delete(array.get(tlLines, i))
    array.clear(tlLines)
    for i = array.size(tlLabels) - 1 to 0
        label.delete(array.get(tlLabels, i))
    array.clear(tlLabels)
    array.clear(trendlines)

    // --- 上升趨勢線 (連接 swing lows) ---
    tlCount = 0
    szLow = array.size(swingLowPrices)
    for a = 0 to math.min(szLow - 2, 10)
        if tlCount >= tlMaxCount / 2
            break
        for b = a + 1 to math.min(szLow - 1, 11)
            if tlCount >= tlMaxCount / 2
                break
            p1 = array.get(swingLowPrices, a)
            b1 = array.get(swingLowBars, a)
            p2 = array.get(swingLowPrices, b)
            b2 = array.get(swingLowBars, b)
            if b2 <= b1 or p2 <= p1
                continue
            barDiff = b2 - b1
            if barDiff == 0
                continue
            slope = (p2 - p1) / barDiff
            touches = 0
            for c = 0 to szLow - 1
                sp = array.get(swingLowPrices, c)
                sb = array.get(swingLowBars, c)
                expectedPrice = p1 + slope * (sb - b1)
                diff = math.abs(sp - expectedPrice)
                if diff <= atrVal * tlTolerance
                    touches += 1
            if touches >= tlMinTouches
                tlType = 1
                if szLow >= 3
                    lastP = array.get(swingLowPrices, szLow - 1)
                    prevP = array.get(swingLowPrices, szLow - 2)
                    if lastP < prevP
                        tlType := 2
                tl = TrendlineInfo.new(p1, b1, p2, b2, slope, touches, tlType, 1)
                array.push(trendlines, tl)
                tlCount += 1

    // --- 下降趨勢線 (連接 swing highs) ---
    tlCount := 0
    szHigh = array.size(swingHighPrices)
    for a = 0 to math.min(szHigh - 2, 10)
        if tlCount >= tlMaxCount / 2
            break
        for b = a + 1 to math.min(szHigh - 1, 11)
            if tlCount >= tlMaxCount / 2
                break
            p1 = array.get(swingHighPrices, a)
            b1 = array.get(swingHighBars, a)
            p2 = array.get(swingHighPrices, b)
            b2 = array.get(swingHighBars, b)
            if b2 <= b1 or p2 >= p1
                continue
            barDiff = b2 - b1
            if barDiff == 0
                continue
            slope = (p2 - p1) / barDiff
            touches = 0
            for c = 0 to szHigh - 1
                sp = array.get(swingHighPrices, c)
                sb = array.get(swingHighBars, c)
                expectedPrice = p1 + slope * (sb - b1)
                diff = math.abs(sp - expectedPrice)
                if diff <= atrVal * tlTolerance
                    touches += 1
            if touches >= tlMinTouches
                tlType = 1
                if szHigh >= 3
                    lastP = array.get(swingHighPrices, szHigh - 1)
                    prevP = array.get(swingHighPrices, szHigh - 2)
                    if lastP > prevP
                        tlType := 2
                tl = TrendlineInfo.new(p1, b1, p2, b2, slope, touches, tlType, -1)
                array.push(trendlines, tl)
                tlCount += 1

    // 繪製趨勢線
    for i = 0 to array.size(trendlines) - 1
        if i < array.size(trendlines)
            tl = array.get(trendlines, i)
            extendedBar = bar_index + tlExtend
            extendedPrice = tl.startPrice + tl.slope * (extendedBar - tl.startBar)
            tlColor = tl.direction == 1 ? color.new(#00e676, 30) : color.new(#ff5252, 30)
            tlStyle = tl.tlType == 1 ? line.style_solid : line.style_dashed
            tlWidth = tl.touches >= 3 ? 2 : 1
            newLine = line.new(tl.startBar, tl.startPrice, extendedBar, extendedPrice,
                              color=tlColor, style=tlStyle, width=tlWidth)
            array.push(tlLines, newLine)
            typeStr = tl.tlType == 1 ? "TL-111" : "TL-11b2"
            touchStr = " (" + str.tostring(tl.touches) + "T)"
            midBar = math.round((tl.startBar + tl.endBar) / 2)
            midPrice = tl.startPrice + tl.slope * (midBar - tl.startBar)
            newLabel = label.new(midBar, midPrice, typeStr + touchStr,
                                color=color.new(color.black, 80), textcolor=tlColor,
                                style=label.style_label_center, size=size.tiny)
            array.push(tlLabels, newLabel)

// 趨勢線突破偵測
tlBreakDetected = false
tlBreakDir = 0
if showTrendlines and array.size(trendlines) > 0
    for i = 0 to array.size(trendlines) - 1
        if i < array.size(trendlines)
            tl = array.get(trendlines, i)
            currentExpected = tl.startPrice + tl.slope * (bar_index - tl.startBar)
            prevExpected    = tl.startPrice + tl.slope * (bar_index - 1 - tl.startBar)
            if tl.direction == -1 and close > currentExpected and close[1] <= prevExpected
                tlBreakDetected := true
                tlBreakDir := 1
            if tl.direction == 1 and close < currentExpected and close[1] >= prevExpected
                tlBreakDetected := true
                tlBreakDir := -1

// ============================================================
// S/R 區域繪製 (Box)
// ============================================================

var box[] zoneBoxes = array.new<box>(0)
var label[] zoneLabels = array.new<label>(0)

if barstate.islast and showZones
    for i = array.size(zoneBoxes) - 1 to 0
        box.delete(array.get(zoneBoxes, i))
    array.clear(zoneBoxes)
    for i = array.size(zoneLabels) - 1 to 0
        label.delete(array.get(zoneLabels, i))
    array.clear(zoneLabels)

    for i = 0 to array.size(levels) - 1
        if i < array.size(levels)
            lv = array.get(levels, i)
            if lv.broken and not showBrokenZones
                continue
            baseColor = lv.levelType == 1 ? color.yellow : lv.levelType == 2 ? color.orange : lv.levelType == 3 ? #00bfff : color.fuchsia
            transp = lv.tested ? (lv.testCount >= 2 ? 92 : 88) : 82
            if lv.broken
                transp := 95
            fillColor = color.new(baseColor, transp)
            borderColor = color.new(baseColor, lv.tested ? 60 : 30)
            borderStyle = lv.tested ? line.style_dashed : line.style_solid
            newBox = box.new(lv.barIdx, lv.zoneTop, bar_index + 20, lv.zoneBot,
                            border_color=borderColor, border_width=1,
                            border_style=borderStyle, bgcolor=fillColor)
            array.push(zoneBoxes, newBox)
            typeStr = lv.levelType == 1 ? "Classic" : lv.levelType == 2 ? "Breakout" : lv.levelType == 3 ? "Gap" : "HNS"
            sideStr = lv.side == 1 ? "S" : "R"
            freshStr = lv.tested ? (str.tostring(lv.testCount) + "x") : "EQ"
            ccStr = lv.hasCC ? (lv.ccType == 1 ? " CC" : lv.ccType == 2 ? " BO1" : lv.ccType == 3 ? " BO2" : lv.ccType == 4 ? " HCC" : "") : ""
            lblText = typeStr + " " + sideStr + " [" + freshStr + "]" + ccStr
            newLbl = label.new(bar_index + 21, lv.price, lblText,
                              color=color.new(color.black, 100), textcolor=color.new(baseColor, lv.tested ? 50 : 0),
                              style=label.style_label_left, size=size.tiny)
            array.push(zoneLabels, newLbl)

// ============================================================
// CC K線高亮
// ============================================================

ccBgColor = color(na)
if showCCHighlight and array.size(levels) > 0
    for i = 0 to array.size(levels) - 1
        if i < array.size(levels)
            lv = array.get(levels, i)
            if lv.hasCC and lv.ccBar == bar_index
                ccBgColor := lv.ccType == 1 ? color.new(#64b5f6, 85) : lv.ccType == 2 ? color.new(#ffb74d, 85) : lv.ccType == 3 ? color.new(#ff8a65, 85) : lv.ccType == 4 ? color.new(#ce93d8, 85) : color.new(color.blue, 85)
                if showCCLabels
                    ccTypeStr = lv.ccType == 1 ? "CC" : lv.ccType == 2 ? "BOCC1" : lv.ccType == 3 ? "BOCC2" : lv.ccType == 4 ? "HNS-CC" : "CC"
                    ccLblStyle = lv.side == 1 ? label.style_label_up : label.style_label_down
                    ccLblY = lv.side == 1 ? low : high
                    label.new(bar_index, ccLblY, ccTypeStr + "\n@" + str.tostring(lv.price, "#.##"),
                             color=color.new(color.black, 70), textcolor=color.new(#64b5f6, 0),
                             style=ccLblStyle, size=size.tiny)

bgcolor(ccBgColor, title="CC K線高亮")

// ============================================================
// 進場訊號偵測 + 詳細標籤 + R/R視覺化
// ============================================================

longSignal  = false
shortSignal = false
signalPrice = 0.0
signalSL    = 0.0
signalTP    = 0.0
signalType  = ""
signalLevelType = ""
signalCCType = ""
signalEQ = false
signalLevelPrice = 0.0

// Setup/DE 組合矩陣: BO & HNS 允許 Direct Entry, Classic & Gap 需 Setup(DC)
isDirectEntry(int levelType) =>
    levelType == 2 or levelType == 4

if array.size(levels) > 0
    for i = 0 to array.size(levels) - 1
        if i < array.size(levels)
            lv = array.get(levels, i)
            if lv.broken
                continue
            if not isLevelFresh(lv)
                continue
            proximity = atrVal * 0.5
            slBuffer  = atrVal * slBufferRatio

            typeStr = lv.levelType == 1 ? "Classic" : lv.levelType == 2 ? "BO" : lv.levelType == 3 ? "Gap" : "HNS"
            ccStr   = lv.ccType == 1 ? "CC" : lv.ccType == 2 ? "BOCC1" : lv.ccType == 3 ? "BOCC2" : lv.ccType == 4 ? "HNS-CC" : "None"

            // === 支撐做多 ===
            if lv.side == 1 and low <= lv.price + proximity
                if useMTF and mtfBias == -1
                    continue
                if entryMode == "DC" or entryMode == "Both"
                    if isBull and close > lv.price and low <= lv.price + proximity
                        if lv.hasCC or not useCC
                            longSignal  := true
                            signalPrice := close
                            signalSL    := lv.price - slBuffer
                            risk        = signalPrice - signalSL
                            signalTP    := signalPrice + risk * defaultTargetR
                            signalType  := "DC LONG"
                            signalLevelType := typeStr
                            signalCCType := ccStr
                            signalEQ := not lv.tested
                            signalLevelPrice := lv.price
                            break
                if not longSignal and (entryMode == "DE" or entryMode == "Both")
                    if lv.strength >= 0.8 and low <= lv.price + atrVal * 0.1
                        longSignal  := true
                        signalPrice := lv.price
                        signalSL    := lv.price - slBuffer - atrVal * 0.2
                        risk        = signalPrice - signalSL
                        signalTP    := signalPrice + risk * defaultTargetR
                        deLabel = isDirectEntry(lv.levelType) ? "DE LONG (Direct)" : "DE LONG (Setup)"
                        signalType  := deLabel
                        signalLevelType := typeStr
                        signalCCType := ccStr
                        signalEQ := not lv.tested
                        signalLevelPrice := lv.price
                        break

            // === 阻力做空 ===
            if lv.side == -1 and high >= lv.price - proximity
                if useMTF and mtfBias == 1
                    continue
                if entryMode == "DC" or entryMode == "Both"
                    if isBear and close < lv.price and high >= lv.price - proximity
                        if lv.hasCC or not useCC
                            shortSignal := true
                            signalPrice := close
                            signalSL    := lv.price + slBuffer
                            risk        = signalSL - signalPrice
                            signalTP    := signalPrice - risk * defaultTargetR
                            signalType  := "DC SHORT"
                            signalLevelType := typeStr
                            signalCCType := ccStr
                            signalEQ := not lv.tested
                            signalLevelPrice := lv.price
                            break
                if not shortSignal and (entryMode == "DE" or entryMode == "Both")
                    if lv.strength >= 0.8 and high >= lv.price - atrVal * 0.1
                        shortSignal := true
                        signalPrice := lv.price
                        signalSL    := lv.price + slBuffer + atrVal * 0.2
                        risk        = signalSL - signalPrice
                        signalTP    := signalPrice - risk * defaultTargetR
                        deLabel = isDirectEntry(lv.levelType) ? "DE SHORT (Direct)" : "DE SHORT (Setup)"
                        signalType  := deLabel
                        signalLevelType := typeStr
                        signalCCType := ccStr
                        signalEQ := not lv.tested
                        signalLevelPrice := lv.price
                        break

// --- 詳細進場標籤 ---
if showDetailedLabels and (longSignal or shortSignal)
    risk = math.abs(signalPrice - signalSL)
    reward = math.abs(signalTP - signalPrice)
    rrRatio = risk > 0 ? reward / risk : 0.0

    line1 = signalType
    line2 = signalLevelType + (longSignal ? " Support" : " Resist.") + " @" + str.tostring(signalLevelPrice, "#.##")
    line3 = "CC: " + signalCCType
    line4 = (signalEQ ? "EQ Fresh" : "Tested") + (useMTF and mtfBias != 0 ? " | MTF " + (mtfBias == 1 ? "Bull" : "Bear") : "")
    line5 = "SL:" + str.tostring(signalSL, "#.##") + " TP:" + str.tostring(signalTP, "#.##") + " RR 1:" + str.tostring(rrRatio, "#.#")

    lblColor = longSignal ? color.new(#00c853, 20) : color.new(#ff1744, 20)
    lblStyle = longSignal ? label.style_label_up : label.style_label_down
    lblY = longSignal ? low - atrVal * 0.3 : high + atrVal * 0.3

    label.new(bar_index, lblY, line1 + "\n" + line2 + "\n" + line3 + "\n" + line4 + "\n" + line5,
             color=lblColor, textcolor=color.white,
             style=lblStyle, size=size.small)

// --- R/R 區域 Box ---
if showRRZones and (longSignal or shortSignal)
    riskColor   = color.new(#ff1744, 85)
    rewardColor = color.new(#00c853, 85)

    if longSignal
        box.new(bar_index, signalPrice, bar_index + 15, signalSL,
               border_color=color.new(#ff1744, 50), bgcolor=riskColor, border_width=1)
        box.new(bar_index, signalTP, bar_index + 15, signalPrice,
               border_color=color.new(#00c853, 50), bgcolor=rewardColor, border_width=1)
        risk = signalPrice - signalSL
        if maxTargetR >= 2
            tp2 = signalPrice + risk * 2
            line.new(bar_index, tp2, bar_index + 15, tp2,
                    color=color.new(#2196f3, 40), style=line.style_dotted, width=1)
            label.new(bar_index + 15, tp2, "+2R",
                     color=color.new(color.black, 100), textcolor=color.new(#2196f3, 0),
                     style=label.style_label_left, size=size.tiny)
        if maxTargetR >= 3
            tp3 = signalPrice + risk * 3
            line.new(bar_index, tp3, bar_index + 15, tp3,
                    color=color.new(#9c27b0, 40), style=line.style_dotted, width=1)
            label.new(bar_index + 15, tp3, "+3R",
                     color=color.new(color.black, 100), textcolor=color.new(#9c27b0, 0),
                     style=label.style_label_left, size=size.tiny)
        label.new(bar_index + 15, signalSL, "-1R",
                 color=color.new(color.black, 100), textcolor=color.new(#ff1744, 0),
                 style=label.style_label_left, size=size.tiny)
        label.new(bar_index + 15, signalTP, "+1R",
                 color=color.new(color.black, 100), textcolor=color.new(#00c853, 0),
                 style=label.style_label_left, size=size.tiny)
        line.new(bar_index, signalPrice, bar_index + 15, signalPrice,
                color=color.new(color.white, 40), style=line.style_solid, width=1)
        label.new(bar_index + 15, signalPrice, "Entry",
                 color=color.new(color.black, 100), textcolor=color.white,
                 style=label.style_label_left, size=size.tiny)

    if shortSignal
        box.new(bar_index, signalSL, bar_index + 15, signalPrice,
               border_color=color.new(#ff1744, 50), bgcolor=riskColor, border_width=1)
        box.new(bar_index, signalPrice, bar_index + 15, signalTP,
               border_color=color.new(#00c853, 50), bgcolor=rewardColor, border_width=1)
        risk = signalSL - signalPrice
        if maxTargetR >= 2
            tp2 = signalPrice - risk * 2
            line.new(bar_index, tp2, bar_index + 15, tp2,
                    color=color.new(#2196f3, 40), style=line.style_dotted, width=1)
            label.new(bar_index + 15, tp2, "+2R",
                     color=color.new(color.black, 100), textcolor=color.new(#2196f3, 0),
                     style=label.style_label_left, size=size.tiny)
        if maxTargetR >= 3
            tp3 = signalPrice - risk * 3
            line.new(bar_index, tp3, bar_index + 15, tp3,
                    color=color.new(#9c27b0, 40), style=line.style_dotted, width=1)
            label.new(bar_index + 15, tp3, "+3R",
                     color=color.new(color.black, 100), textcolor=color.new(#9c27b0, 0),
                     style=label.style_label_left, size=size.tiny)
        label.new(bar_index + 15, signalSL, "-1R",
                 color=color.new(color.black, 100), textcolor=color.new(#ff1744, 0),
                 style=label.style_label_left, size=size.tiny)
        label.new(bar_index + 15, signalTP, "+1R",
                 color=color.new(color.black, 100), textcolor=color.new(#00c853, 0),
                 style=label.style_label_left, size=size.tiny)
        line.new(bar_index, signalPrice, bar_index + 15, signalPrice,
                color=color.new(color.white, 40), style=line.style_solid, width=1)
        label.new(bar_index + 15, signalPrice, "Entry",
                 color=color.new(color.black, 100), textcolor=color.white,
                 style=label.style_label_left, size=size.tiny)

// ============================================================
// 警報引擎
// ============================================================

// --- 接近水平警報 ---
levelApproaching = false
if enableAlerts and array.size(levels) > 0
    for i = 0 to array.size(levels) - 1
        if i < array.size(levels)
            lv = array.get(levels, i)
            if lv.broken or lv.tested
                continue
            dist = math.abs(close - lv.price)
            if dist <= atrVal * 0.3
                levelApproaching := true
                break

// --- CC形成警報 ---
ccFormed = false
if enableAlerts and array.size(levels) > 0
    for i = 0 to array.size(levels) - 1
        if i < array.size(levels)
            lv = array.get(levels, i)
            if lv.hasCC and lv.ccBar == bar_index
                ccFormed := true
                break

// --- 水平突破警報 ---
levelBroken = false
if enableAlerts and array.size(levels) > 0
    for i = 0 to array.size(levels) - 1
        if i < array.size(levels)
            lv = array.get(levels, i)
            if lv.broken
                brokenThisBar = false
                if lv.side == 1 and close < lv.price - atrVal * 0.5 and close[1] >= lv.price - atrVal * 0.5
                    brokenThisBar := true
                if lv.side == -1 and close > lv.price + atrVal * 0.5 and close[1] <= lv.price + atrVal * 0.5
                    brokenThisBar := true
                if brokenThisBar
                    levelBroken := true
                    break

// --- Alert Conditions ---
alertcondition(longSignal, "Long DC/DE 進場", "SNR2 LONG: Entry signal detected")
alertcondition(shortSignal, "Short DC/DE 進場", "SNR2 SHORT: Entry signal detected")
alertcondition(levelApproaching, "價格接近新鮮水平", "SNR2: Price approaching fresh level")
alertcondition(ccFormed, "CC K線形成", "SNR2: Confirmation candle formed")
alertcondition(levelBroken, "水平被突破", "SNR2: Level broken")
alertcondition(tlBreakDetected, "趨勢線突破", "SNR2: Trendline broken")
alertcondition(mtfChanged, "MTF方向改變", "SNR2: MTF bias changed")

// 綜合警報 (Webhook JSON)
anySignal = longSignal or shortSignal
if anySignal and enableAlerts
    dir = longSignal ? "LONG" : "SHORT"
    alertMsg = '{"signal":"' + dir + '","type":"' + signalType + '","level":"' + signalLevelType + '","price":' + str.tostring(signalPrice) + ',"sl":' + str.tostring(signalSL) + ',"tp":' + str.tostring(signalTP) + ',"cc":"' + signalCCType + '","eq":' + (signalEQ ? '"fresh"' : '"tested"') + ',"mtf":' + str.tostring(mtfBias) + '}'
    alert(alertMsg, alert.freq_once_per_bar_close)

// ============================================================
// 速查表 + 情境檢查清單
// ============================================================

// --- Setup/DE 組合速查表 (bottom_left) ---
var table cheatPanel = table.new(position.bottom_left, 4, 8,
                                  bgcolor=color.new(#0d1117, 5),
                                  border_color=color.new(color.gray, 60), border_width=1)

if barstate.islast and showCheatSheet
    table.cell(cheatPanel, 0, 0, "Setup/DE", text_color=color.white, text_size=size.tiny)
    table.cell(cheatPanel, 1, 0, "DC", text_color=color.white, text_size=size.tiny)
    table.cell(cheatPanel, 2, 0, "DE", text_color=color.white, text_size=size.tiny)
    table.cell(cheatPanel, 3, 0, "Quality", text_color=color.white, text_size=size.tiny)

    table.cell(cheatPanel, 0, 1, "Classic", text_color=color.yellow, text_size=size.tiny)
    table.cell(cheatPanel, 1, 1, "Setup", text_color=color.green, text_size=size.tiny, bgcolor=color.new(color.green, 85))
    table.cell(cheatPanel, 2, 1, "Setup", text_color=#ffeb3b, text_size=size.tiny, bgcolor=color.new(#ffeb3b, 85))
    table.cell(cheatPanel, 3, 1, "Good", text_color=color.green, text_size=size.tiny)

    table.cell(cheatPanel, 0, 2, "Breakout", text_color=color.orange, text_size=size.tiny)
    table.cell(cheatPanel, 1, 2, "Setup", text_color=color.green, text_size=size.tiny, bgcolor=color.new(color.green, 85))
    table.cell(cheatPanel, 2, 2, "Direct", text_color=#00e676, text_size=size.tiny, bgcolor=color.new(#00e676, 80))
    table.cell(cheatPanel, 3, 2, "Best", text_color=#00e676, text_size=size.tiny)

    table.cell(cheatPanel, 0, 3, "Gap", text_color=#00bfff, text_size=size.tiny)
    table.cell(cheatPanel, 1, 3, "Setup", text_color=color.green, text_size=size.tiny, bgcolor=color.new(color.green, 85))
    table.cell(cheatPanel, 2, 3, "Setup", text_color=#ffeb3b, text_size=size.tiny, bgcolor=color.new(#ffeb3b, 85))
    table.cell(cheatPanel, 3, 3, "OK", text_color=#ffeb3b, text_size=size.tiny)

    table.cell(cheatPanel, 0, 4, "HNS", text_color=color.fuchsia, text_size=size.tiny)
    table.cell(cheatPanel, 1, 4, "Setup", text_color=color.green, text_size=size.tiny, bgcolor=color.new(color.green, 85))
    table.cell(cheatPanel, 2, 4, "Direct", text_color=#00e676, text_size=size.tiny, bgcolor=color.new(#00e676, 80))
    table.cell(cheatPanel, 3, 4, "Best", text_color=#00e676, text_size=size.tiny)

    table.cell(cheatPanel, 0, 5, "------", text_color=color.gray, text_size=size.tiny)
    table.cell(cheatPanel, 1, 5, "------", text_color=color.gray, text_size=size.tiny)
    table.cell(cheatPanel, 2, 5, "------", text_color=color.gray, text_size=size.tiny)
    table.cell(cheatPanel, 3, 5, "------", text_color=color.gray, text_size=size.tiny)

    table.cell(cheatPanel, 0, 6, "Rules", text_color=color.white, text_size=size.tiny)
    table.cell(cheatPanel, 1, 6, "CC dir = Trade dir", text_color=color.gray, text_size=size.tiny)
    table.cell(cheatPanel, 2, 6, "", text_color=color.gray, text_size=size.tiny)
    table.cell(cheatPanel, 3, 6, "", text_color=color.gray, text_size=size.tiny)
    table.cell(cheatPanel, 0, 7, "", text_color=color.white, text_size=size.tiny)
    table.cell(cheatPanel, 1, 7, "EQ = untested only", text_color=color.gray, text_size=size.tiny)
    table.cell(cheatPanel, 2, 7, "", text_color=color.gray, text_size=size.tiny)
    table.cell(cheatPanel, 3, 7, "", text_color=color.gray, text_size=size.tiny)

// --- 情境檢查清單 (bottom_right) ---
var table checkPanel = table.new(position.bottom_right, 2, 7,
                                  bgcolor=color.new(#0d1117, 5),
                                  border_color=color.new(color.gray, 60), border_width=1)

if barstate.islast and showChecklist
    table.cell(checkPanel, 0, 0, "Checklist", text_color=color.white, text_size=size.tiny)
    table.cell(checkPanel, 1, 0, "Status", text_color=color.white, text_size=size.tiny)

    // 1. 新鮮水平附近?
    nearestFreshDist = 999999.0
    nearestFreshType = ""
    if array.size(levels) > 0
        for i = 0 to array.size(levels) - 1
            if i < array.size(levels)
                lv = array.get(levels, i)
                if not lv.broken and not lv.tested
                    dist = math.abs(close - lv.price)
                    if dist < nearestFreshDist
                        nearestFreshDist := dist
                        nearestFreshType := lv.levelType == 1 ? "C" : lv.levelType == 2 ? "BO" : lv.levelType == 3 ? "G" : "HNS"

    freshNearby = nearestFreshDist < atrVal * 1.0
    freshDistATR = atrVal > 0 ? nearestFreshDist / atrVal : 999.0
    table.cell(checkPanel, 0, 1, "Fresh Level", text_color=color.gray, text_size=size.tiny)
    freshTxt = freshNearby ? nearestFreshType + " " + str.tostring(freshDistATR, "#.#") + " ATR" : "None nearby"
    freshCol = freshNearby ? color.green : color.red
    table.cell(checkPanel, 1, 1, freshTxt, text_color=freshCol, text_size=size.tiny)

    // 2. CC 存在?
    anyCC = false
    ccTypeDisplay = ""
    if array.size(levels) > 0
        for i = 0 to array.size(levels) - 1
            if i < array.size(levels)
                lv = array.get(levels, i)
                if not lv.broken and lv.hasCC and not lv.tested
                    anyCC := true
                    ccTypeDisplay := lv.ccType == 1 ? "Classic" : lv.ccType == 2 ? "BOCC1" : lv.ccType == 3 ? "BOCC2" : lv.ccType == 4 ? "HNS" : "Yes"
                    break
    table.cell(checkPanel, 0, 2, "CC Present", text_color=color.gray, text_size=size.tiny)
    table.cell(checkPanel, 1, 2, anyCC ? ccTypeDisplay : "No", text_color=anyCC ? color.green : #ffeb3b, text_size=size.tiny)

    // 3. MTF 方向
    table.cell(checkPanel, 0, 3, "MTF Aligned", text_color=color.gray, text_size=size.tiny)
    mtfStr = mtfBias == 1 ? "Bull" : mtfBias == -1 ? "Bear" : "Neutral"
    mtfCol = mtfBias == 1 ? color.green : mtfBias == -1 ? color.red : color.gray
    table.cell(checkPanel, 1, 3, mtfStr, text_color=mtfCol, text_size=size.tiny)

    // 4. 趨勢線支撐
    hasTLSupport = false
    if array.size(trendlines) > 0
        for i = 0 to array.size(trendlines) - 1
            if i < array.size(trendlines)
                tl = array.get(trendlines, i)
                expectedPrice = tl.startPrice + tl.slope * (bar_index - tl.startBar)
                if tl.direction == 1 and math.abs(close - expectedPrice) < atrVal * 0.5 and close >= expectedPrice
                    hasTLSupport := true
                    break
    table.cell(checkPanel, 0, 4, "TL Support", text_color=color.gray, text_size=size.tiny)
    table.cell(checkPanel, 1, 4, hasTLSupport ? "Yes" : "No", text_color=hasTLSupport ? color.green : color.gray, text_size=size.tiny)

    // 5. 整體評分
    score = 0
    if freshNearby
        score += 1
    if anyCC
        score += 1
    if mtfBias != 0
        score += 1
    if hasTLSupport
        score += 1
    grade = score >= 4 ? "A" : score >= 3 ? "B" : score >= 2 ? "C" : "D"
    gradeCol = score >= 4 ? #00e676 : score >= 3 ? color.green : score >= 2 ? #ffeb3b : color.red
    table.cell(checkPanel, 0, 5, "Grade", text_color=color.white, text_size=size.tiny)
    table.cell(checkPanel, 1, 5, grade + " (" + str.tostring(score) + "/4)", text_color=gradeCol, text_size=size.tiny)

    // 6. ATR 數值
    table.cell(checkPanel, 0, 6, "ATR(14)", text_color=color.gray, text_size=size.tiny)
    table.cell(checkPanel, 1, 6, str.tostring(atrVal, "#.####"), text_color=color.white, text_size=size.tiny)

// ============================================================
// END
// ============================================================
